# Early-Stress — Environment Variables
# Copy this file to .env and fill in your values

# ─── Security ───────────────────────────────────────
# IMPORTANT: Change this to a random 64-char string in production!
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars-long

# ─── Data Storage ───────────────────────────────────
USERS_FILE=users.json
BEHAVIOR_FILE=behavior_logs.json
HISTORY_FILE=prediction_history.json

# ─── Server ─────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Production (optional) ──────────────────────────
# DATABASE_URL=postgresql://user:password@localhost/earlystress
# REDIS_URL=redis://localhost:6379
